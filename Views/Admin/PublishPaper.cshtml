@model PublishPaperViewModel
@{
    ViewData["Title"] = "Publish Paper"; Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="data-table">
            <div class="p-3 border-bottom"><h5 class="mb-0">Publish Paper</h5></div>
            <div class="p-4">
                <div class="alert alert-info">
                    <strong>Paper:</strong> @Model.PaperTitle<br>
                    <strong>Authors:</strong> @Model.Authors
                </div>
                <form asp-action="PublishPaper" asp-route-id="@Model.SubmissionId" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="SubmissionId" />
                    <div class="mb-3">
                        <label asp-for="IssueId" class="form-label">Select Issue *</label>
                        <select asp-for="IssueId" asp-items="Model.Issues" class="form-select"><option value="">Select Issue</option></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DOI" class="form-label">DOI *</label>
                        <input asp-for="DOI" class="form-control" placeholder="e.g., 10.xxxxx/ijulr.2026.001" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PageStart" class="form-label">Page Start *</label>
                            <input asp-for="PageStart" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PageEnd" class="form-label">Page End *</label>
                            <input asp-for="PageEnd" type="number" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreativeComments" class="form-label">Creative Comments</label>
                        <textarea asp-for="CreativeComments" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Certificate PDF <span class="text-danger">*</span></label>
                        <input type="file" name="CertificatePdf" class="form-control" accept=".pdf" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CopyrightInfo" class="form-label">Copyright Information</label>
                        <textarea asp-for="CopyrightInfo" class="form-control" rows="2" placeholder="© 2026 Author(s). This is an open access article..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-journal-check me-2"></i>Publish Now</button>
                        <a href="/editorial/submission/@Model.SubmissionId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
