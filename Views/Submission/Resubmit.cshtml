@model Submission
@{ViewData["Title"] = "Submit Revised Manuscript";}

<section class="page-content">
    <div class="container">
        <h1 class="page-title">Submit Revised Manuscript</h1>
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        <div class="alert alert-warning mb-4">
                            <h5>Revision Required</h5>
                            <p class="mb-0">@Model.RevisionComments</p>
                        </div>
                        <p><strong>Tracking ID:</strong> @Model.TrackingId</p>
                        <p><strong>Paper:</strong> @Model.PaperTitle</p>
                        <hr>
                        <form asp-action="Resubmit" method="post" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label">Revised Manuscript (PDF/Word)</label>
                                <input type="file" name="manuscript" class="form-control" accept=".pdf,.doc,.docx" required />
                            </div>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-2"></i>Submit Revised Manuscript</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
