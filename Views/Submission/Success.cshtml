@model Submission
@{ViewData["Title"] = "Submission Successful";}

<section class="page-content">
    <div class="container">
        <div class="text-center mb-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size:5rem"></i>
            <h1 class="mt-3">Submission Successful!</h1>
            <p class="text-muted">Your paper has been submitted successfully.</p>
        </div>
        <div class="card mx-auto" style="max-width:600px">
            <div class="card-body text-center">
                <div class="alert alert-success">
                    <h4 class="mb-0">Tracking ID: <strong>@Model.TrackingId</strong></h4>
                </div>
                <p><strong>Paper Title:</strong> @Model.PaperTitle</p>
                <p><strong>Corresponding Author:</strong> @Model.PrimaryAuthor?.FullName</p>
                <p><strong>Email:</strong> @Model.PrimaryAuthor?.Email</p>
                <hr>
                <p class="text-muted small">Please save your Tracking ID. You will need it along with your email to track your submission status.</p>
                <a href="/Submission/Track" class="btn btn-primary"><i class="bi bi-search me-2"></i>Track Submission</a>
                <a href="/" class="btn btn-outline-secondary ms-2">Back to Home</a>
            </div>
        </div>
    </div>
</section>
