@using IJULR.Web.Helpers
            @inject FileUrlHelper FileUrlHelper


@{
    var settings = ViewBag.Settings as Dictionary<string, string> ?? new Dictionary<string, string>();
    string GetSetting(string key, string def = "") => settings.GetValueOrDefault(key, def);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IJULR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&family=Merriweather:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1a4f7a;
            --secondary: #2874a6;
            --accent: #f39c12;
            --light: #f8f9fa;
            --dark: #1a252f
        }

        body {
            font-family: 'Open Sans',sans-serif;
            color: #333
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Merriweather',serif;
            color: var(--primary)
        }

        .top-bar {
            background: var(--dark);
            color: #fff;
            padding: 8px 0;
            font-size: .85rem
        }

            .top-bar a {
                color: #ccc;
                text-decoration: none
            }

                .top-bar a:hover {
                    color: #fff
                }

        .header-main {
            background: #fff;
            padding: 20px 0;
            box-shadow: 0 2px 10px rgba(0,0,0,.1)
        }

        .logo-text h1 {
            font-size: 1.5rem;
            margin: 0;
            color: var(--primary)
        }

        .logo-text p {
            margin: 0;
            font-size: .85rem;
            color: #666
        }

        .main-nav {
            background: linear-gradient(135deg,var(--primary),var(--secondary))
        }

            .main-nav .navbar-nav .nav-link {
                color: #fff !important;
                font-weight: 600;
                padding: 15px 18px;
                transition: all .3s
            }

                .main-nav .navbar-nav .nav-link:hover {
                    background: rgba(255,255,255,.15)
                }

            .main-nav .dropdown-menu {
                border: none;
                border-radius: 0;
                box-shadow: 0 5px 15px rgba(0,0,0,.15);
                margin-top: 0
            }

            .main-nav .dropdown-item {
                padding: 10px 20px
            }

                .main-nav .dropdown-item:hover {
                    background: var(--primary);
                    color: #fff
                }

        .hero-section {
            background: linear-gradient(135deg,var(--primary) 0%,var(--secondary) 100%);
            color: #fff;
            padding: 60px 0
        }

            .hero-section h1 {
                font-size: 2.5rem;
                margin-bottom: 20px
            }

        .page-content {
            padding: 50px 0;
            min-height: 60vh
        }

        .page-title {
            color: var(--primary);
            border-left: 4px solid var(--accent);
            padding-left: 15px;
            margin-bottom: 30px
        }

        .sidebar-widget {
            background: #fff;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05)
        }

            .sidebar-widget h5 {
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
                padding-bottom: 10px;
                margin-bottom: 15px
            }

        .btn-primary {
            background: var(--primary);
            border-color: var(--primary)
        }

            .btn-primary:hover {
                background: var(--secondary);
                border-color: var(--secondary)
            }

        .btn-accent {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff
        }

        .card {
            border: none;
            box-shadow: 0 2px 15px rgba(0,0,0,.08);
            transition: transform .3s
        }

            .card:hover {
                transform: translateY(-3px)
            }

        .footer {
            background: var(--dark);
            color: #aaa;
            padding: 50px 0 20px
        }

            .footer h5 {
                color: #fff;
                margin-bottom: 20px
            }

            .footer a {
                color: #aaa
            }

                .footer a:hover {
                    color: var(--accent)
                }

        .footer-bottom {
            border-top: 1px solid #333;
            padding-top: 20px;
            margin-top: 30px
        }

        .paper-item {
            border-left: 3px solid var(--accent);
            padding: 20px;
            margin-bottom: 20px;
            background: #fff;
            box-shadow: 0 2px 10px rgba(0,0,0,.05)
        }

            .paper-item h5 a {
                color: var(--primary);
                text-decoration: none
            }

                .paper-item h5 a:hover {
                    color: var(--secondary)
                }

        .badge-status {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: .8rem
        }
    </style>
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <i class="bi bi-envelope me-1"></i> @GetSetting("ContactEmail", "info@ijulr.com")
                @if (!string.IsNullOrEmpty(GetSetting("ContactPhone")))
                {
                    <span class="ms-3"><i class="bi bi-phone me-1"></i> @GetSetting("ContactPhone")</span>
                }
            </div>
            <div>
                <a href="/Submission/Submit" class="me-3"><i class="bi bi-upload me-1"></i> Submit Paper</a>
                <a href="/Submission/Track"><i class="bi bi-search me-1"></i> Track Submission</a>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header class="header-main">
        <div class="container d-flex align-items-center">

            <img src="@FileUrlHelper.GetDirectCloudUrl(GetSetting("LogoPath"))"
                 alt="IJULR"
                 style="max-height:70px"
                 onerror="this.style.display='none'">

            <div class="logo-text ms-3">
                <h1>@GetSetting("JournalAbbreviation", "IJULR")</h1>
                <p>@GetSetting("JournalName", "International Journal of Unified Law Research")</p>
            </div>
        </div>
    </header>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg main-nav">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" style="border-color:#fff">
                <i class="bi bi-list text-white fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">About</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Home/About">About the Journal</a></li>
                            <li><a class="dropdown-item" href="/Home/AimsScope">Aims and Scope</a></li>
                            <li><a class="dropdown-item" href="/Home/Objectives">Objectives</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Information</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Home/ReviewProcess">Review Process</a></li>
                            <li><a class="dropdown-item" href="/Home/PublicationProcess">Publication Process</a></li>
                            <li><a class="dropdown-item" href="/Home/AuthorGuidelines">Guidelines for Authors</a></li>
                            <li><a class="dropdown-item" href="/Home/ReviewerGuidelines">Guidelines for Reviewers</a></li>
                            <li><a class="dropdown-item" href="/Home/EditorGuidelines">Guidelines for Editors</a></li>
                            <li><a class="dropdown-item" href="/Home/FormattingStyle">Formatting Style</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Policies</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Home/PublicationEthics">Publication Ethics & Malpractice</a></li>
                            <li><a class="dropdown-item" href="/Home/PublicationPolicy">Publication Policy</a></li>
                            <li><a class="dropdown-item" href="/Home/PeerReviewPolicy">Peer Review Policy</a></li>
                            <li><a class="dropdown-item" href="/Home/PlagiarismPolicy">Ethics & Plagiarism Policy</a></li>
                            <li><a class="dropdown-item" href="/Home/Licensing">Licensing Information</a></li>
                            <li><a class="dropdown-item" href="/Home/OpenAccess">Open Access Policy</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Issues</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Issue/CurrentIssue">Current Issue</a></li>
                            <li><a class="dropdown-item" href="/Issue/Archives">Archives</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/Home/EditorialBoard">Editorial Board</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Contact">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3"><div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3"><div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div></div>
        }
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5>IJULR</h5>
                    <p>International Journal of Unified Law Research - A peer-reviewed, open-access academic journal.</p>
                </div>
                <div class="col-md-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="/Submission/Submit">Submit Paper</a></li>
                        <li><a href="/Submission/Track">Track Submission</a></li>
                        <li><a href="/Issue/CurrentIssue">Current Issue</a></li>
                        <li><a href="/Issue/Archives">Archives</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>Contact</h5>
                    <p><i class="bi bi-envelope me-2"></i>@GetSetting("ContactEmail", "info@ijulr.com")</p>
                    <p><i class="bi bi-globe me-2"></i>@GetSetting("WebsiteUrl", "www.ijulr.com")</p>
                </div>
            </div>
            <div class="footer-bottom text-center">
                <p class="mb-0">@GetSetting("CopyrightText", "© 2026 IJULR. All Rights Reserved.")</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
