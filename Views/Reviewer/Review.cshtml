@model SubmitReviewViewModel
@{Layout = null;}
<!DOCTYPE html>
<html>
<head>
    <title>Submit Review - IJULR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <span class="navbar-brand">IJULR - Submit Review</span>
            <a href="/reviewer/dashboard" class="btn btn-outline-light btn-sm">Back to Dashboard</a>
        </div>
    </nav>
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header bg-primary text-white"><h5 class="mb-0">Submit Your Review</h5></div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <strong>Paper:</strong> @Model.PaperTitle
                        </div>
                        @if(!string.IsNullOrEmpty(Model.Abstract)){
                            <div class="mb-4">
                                <strong>Abstract:</strong>
                                <p class="small">@Model.Abstract</p>
                            </div>
                        }
                        <form asp-action="Review" asp-route-id="@Model.AssignmentId" method="post">
                            <input type="hidden" asp-for="AssignmentId" />
                            <input type="hidden" asp-for="SubmissionId" />
                            <div class="mb-3">
                                <label class="form-label">Score (1-5) *</label>
                                <select asp-for="Score" class="form-select">
                                    <option value="">Select Score</option>
                                    <option value="1">1 - Poor</option>
                                    <option value="2">2 - Below Average</option>
                                    <option value="3">3 - Average</option>
                                    <option value="4">4 - Good</option>
                                    <option value="5">5 - Excellent</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Recommendation *</label>
                                <select asp-for="Recommendation" asp-items="SubmitReviewViewModel.Recommendations" class="form-select">
                                    <option value="">Select Recommendation</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Comments * <small class="text-muted">(minimum 50 characters)</small></label>
                                <textarea asp-for="Comments" class="form-control" rows="8" placeholder="Please provide detailed feedback for the author..."></textarea>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Submit Review</button>
                                <a href="/reviewer/dashboard" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
